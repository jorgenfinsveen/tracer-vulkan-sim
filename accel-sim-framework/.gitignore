printf "%-11s %-8s %-43s %-8s %s\n" ID USER JOB TIME NODE && echo "" && squeue -h -u "$USER,olekd" -o "%.8i %.8u    %.40j %.8M    %N"

{
  hdr=$(printf "%-11s %-8s %-43s %-8s %s\n" ID USER JOB TIME NODE)
  echo "$hdr"
  printf "%*s\n" "$(( ${#hdr} + 6 ))" "" | tr ' ' '-'
  squeue -h -u "$USER,olekd" -o "%.8i %.8u    %.40j %.8M    %N" | sort -k2,2
}