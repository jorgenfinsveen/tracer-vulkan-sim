#!/usr/bin/env bash
#SBATCH --partition=CPUQ
#SBATCH --job-name=post_job
#SBATCH --account=share-ie-idi
#SBATCH --mem=32G
#SBATCH --cpus-per-task=1
#SBATCH --output=/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/util/job_launching/out.log
#SBATCH --error=/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/util/job_launching/err.log

export GPGPUSIM_ROOT=/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/gpu-simulator/gpgpu-sim
export ACCEL_SIM="/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/pipeline/../"

if [ -f "/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/pipeline/utility/update_logs.py" ]; then
    python3 "/cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/pipeline/utility/update_logs.py" \
        --target 2026_02_05__21_53 \
        --logs /cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/pipeline/results/output/more_streaming_multiprocessors/../simulator_logs.yaml \
        --pipeline /cluster/home/jorgfi/projects/crisp_framework/accel-sim-framework/pipeline/setup/pipeline.yaml \
        --job_name minitrace-NO_ARGS.accelsim-commit-554c9ea810c802b3e82dc68df2d8a1612d7df2c3_modified_0.0_20260122-1427gpgpu-sim_git-commit-0c0ecddf9512cfe0f50c4107fea59208c08b7432_modified_0.0 
